@model LeviathanerProgramming.Models.ViewModels.ListaVM;
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h4>
                            Crear Tipo Ruta Aprendizaje
                            <a class="btn btn-danger float-end" asp-controller="TipoRutaAprendizaje" asp-action="Lista">Regresar</a>
                        </h4>
                    </div>

                    <div class="card-body">
                        <form asp-controller="TipoRutaAprendizaje" asp-action="Nuevo" method="post">
                            <input asp-for="oTipoRutaAprendizaje.IdRutaAprendizaje" type="hidden" />


                            <div class="mb-3">
                                <label>Nombre Tipo Aprendizaje</label>
                                <input class="form-control" type="text" asp-for="oTipoRutaAprendizaje.NombreTipoAprenidzaje">
                                <span asp-validation-for="oTipoRutaAprendizaje.NombreTipoAprenidzaje"></span>
                            </div>

                            <div class="mb-3">
                                <label>Lista RoadMap</label>
                                <select class="form-control" asp-for="oTipoRutaAprendizaje.Road_Map_Id" asp-items="@Model.oListaRoadMap">
                                    <option selected disabled>-- Seleccionar --</option>
                                </select>
                                <span asp-validation-for="oTipoRutaAprendizaje.Road_Map_Id"></span>
                            </div>

                            <button class="btn btn-primary" type="submit">Crear</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
